# Base origin of the Laravel notes app (no trailing slash, no /api).
# The MCP server appends /api/... itself.
LARAVEL_API_URL=http://localhost

# Public URL this MCP server is reachable at. For ChatGPT this MUST be the
# HTTPS URL of your tunnel / deployment (e.g. https://notes-mcp.example.com or
# an ngrok/cloudflared URL). Used as the OAuth issuer and in discovery metadata.
MCP_SERVER_URL=http://localhost:3100

# Port the HTTP server listens on.
PORT=3100

# Transport: "http" (remote / ChatGPT) or "stdio" (local Inspector / Claude Desktop).
TRANSPORT=http

# Must match backend MCP_STORAGE_SECRET. Used only by this MCP service to store
# OAuth clients/codes/tokens in the Laravel MySQL database.
MCP_STORAGE_SECRET=change-me-to-a-long-random-secret

# --- stdio mode only ---
# When TRANSPORT=stdio there is no OAuth flow; provide a Sanctum token directly.
# Mint one with:  curl -X POST $LARAVEL_API_URL/api/mcp/token -H 'Accept: application/json' \
#                   -d 'username=YOU' -d 'password=SECRET'
# NOTES_API_TOKEN=1|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
